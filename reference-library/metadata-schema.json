{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reference Set Metadata",
  "type": "object",
  "required": ["id", "type", "tags", "created"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+_[a-z0-9_]+$",
      "description": "Unique identifier (type_name_version)"
    },
    "type": {
      "type": "string",
      "enum": ["character", "style", "product", "environment", "lighting", "composition"]
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 1
    },
    "style": {
      "type": "string",
      "description": "Visual style descriptor"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "flux_params": {
      "type": "object",
      "properties": {
        "model": {"type": "string"},
        "guidance": {"type": "number"},
        "steps": {"type": "integer"}
      }
    },
    "runway_params": {
      "type": "object",
      "properties": {
        "model": {"type": "string"},
        "duration": {"type": "integer"}
      }
    },
    "notes": {
      "type": "string"
    },
    "parent_refs": {
      "type": "array",
      "items": {"type": "string"},
      "description": "IDs of reference sets this derives from"
    }
  }
}
